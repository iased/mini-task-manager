{% extends 'base.html.twig' %}

{% block title %}My Tasks{% endblock %}

{% block body %}

<h1>My Tasks</h1>

<a href="{{ path('app_task_new') }}">Create Task</a>

<p>
    Filter:
    <a href="{{ path('app_task_index') }}">All</a> |
    <a href="{{ path('app_task_index', {status: 'open'}) }}">Open</a> |
    <a href="{{ path('app_task_index', {status: 'done'}) }}">Done</a>
</p>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Status</th>
            <th>Created at</th>
            <th>Updated at</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
    {% for task in tasks %}
        <tr>
            <td>{{ task.title }}</td>
            <td>{{ task.description }}</td>
            <td>
                {% if task.isDone %}
                    Done
                {% else %}
                    Open
                {% endif %}
            </td>
            <td>{{ task.createdAt|date('Y-m-d H:i') }}</td>
            <td>
                {% if task.updatedAt %}
                    {{ task.updatedAt|date('Y-m-d H:i') }}
                {% else %}
                    -
                {% endif %}
            </td>
            <td>
                <a href="{{ path('app_task_edit', {id: task.id}) }}">Edit</a>

                <form method="post"
                    action="{{ path('app_task_toggle', {id: task.id}) }}"
                    style="display:inline;"
                >
                    <input type="hidden"
                        name="_token"
                        value="{{ csrf_token('toggle' ~ task.id) }}"
                    >

                    <button type="submit">
                        {% if task.isDone %}
                            Reopen
                        {% else %}
                            Mark as Done
                        {% endif %}
                    </button>
                </form>

                <form method="post"
                    action="{{ path('app_task_delete', {id: task.id}) }}"
                    style="display:inline;"
                >
                    <input type="hidden"
                        name="_token"
                        value="{{ csrf_token('delete' ~ task.id) }}"
                    >

                    <button type="submit"
                            onclick="return confirm('Are you sure you want to delete this task?');"
                    >
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="3">No tasks yet</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}
