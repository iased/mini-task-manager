{% extends 'base.html.twig' %}

{% block title %}Mini Task Manager{% endblock %}

{% block body %}

<section class="tasks-page">
    <p class="tasks-subtitle">Stay organized and productive</p>

    <div class="top-actions">
        <form method="get" action="{{ path('app_task_index') }}" class="search-form">
            <input 
                type="text" 
                name="search" 
                placeholder="Search by title..."
                value="{{ current_search }}"
                class="search-input"
            >

            {% if current_status %}
                <input type="hidden" name="status" value="{{ current_status }}">
            {% endif %}

            <button type="submit" class="secondary-button search-button">Search</button>
        </form>

        <a href="{{ path('app_task_new') }}" class="primary-button create-button"><b>+</b> &nbspNew Task</a>
    </div>

    <div class="task-card">
        <div class="task-filters">
            <a 
                href="{{ path('app_task_index', {'search': current_search}) }}"
                class="filter-btn {{ current_status is empty ? 'active' : '' }}"
            >
                All
            </a>
            <a 
                href="{{ path('app_task_index', {'status': 'open', 'search': current_search}) }}"
                class="filter-btn {{ current_status == 'open' ? 'active' : '' }}"
            >
                Active
            </a>
            <a 
                href="{{ path('app_task_index', {'status': 'done', 'search': current_search}) }}"
                class="filter-btn {{ current_status == 'done' ? 'active' : '' }}"
            >
                Completed
            </a>
        </div>

        {% if tasks is empty %}
            <div class="empty-state">
                No tasks yet. Add one to get started!
            </div>
        {% else %}
            <div class="task-list">
                {% for task in tasks %}
                    <div class="task-row">
                        <div class="task-main">
                            <div class="task-title-row">
                                <h3 class="task-title">
                                    {{ task.title }}
                                </h3>

                                <span class="task-status {{ task.isDone ? 'done' : 'open' }}">
                                    {{ task.isDone ? 'Done' : 'Open' }}
                                </span>
                            </div>

                            {% if task.description %}
                                <p class="task-description">{{ task.description }}</p>
                            {% endif %}

                            <div class="task-meta">
                                <div>Created: {{ task.createdAt|date('Y-m-d H:i') }}</div>
                                <div>
                                    {% if task.updatedAt %}
                                    Updated:
                                        {{ task.updatedAt|date('Y-m-d H:i') }}
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="task-actions">
                            <a href="{{ path('app_task_edit', {id: task.id}) }}" class="secondary-button">
                                Edit
                            </a>

                            <form method="post" action="{{ path('app_task_toggle', {id: task.id}) }}">
                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('toggle' ~ task.id) }}"
                                >

                                <button type="submit" class="secondary-button">
                                    {% if task.isDone %}
                                        Reopen
                                    {% else %}
                                        Mark done
                                    {% endif %}
                                </button>
                            </form>

                            <form method="post" action="{{ path('app_task_delete', {id: task.id}) }}">
                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('delete' ~ task.id) }}"
                                >

                                <button
                                    type="submit"
                                    class="danger-button"
                                    onclick="return confirm('Are you sure you want to delete this task?');"
                                >
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% endblock %}
