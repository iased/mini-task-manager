{% extends 'base.html.twig' %}

{% block title %}My Tasks{% endblock %}

{% block body %}

<h1>My Tasks</h1>

<a href="{{ path('app_task_new') }}">Create Task</a>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Created at</th>
        </tr>
    </thead>

    <tbody>
    {% for task in tasks %}
        <tr>
            <td>{{ task.title }}</td>
            <td>
                {% if task.isDone %}
                    Done
                {% else %}
                    Open
                {% endif %}
            </td>
            <td>{{ task.createdAt|date('Y-m-d H:i') }}</td>
        </tr>
    {% else %}
        <tr>
            <td colspan="3">No tasks yet</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}
