{% extends 'base.html.twig' %}

{% block title %}Edit Task{% endblock %}

{% block body %}

<h1>Edit Task</h1>

{{ form_start(form) }}
    {{ form_row(form.title) }}
    {{ form_row(form.description) }}
    {{ form_row(form.isDone) }}

    <button>Save</button>
{{ form_end(form) }}

<a href="{{ path('app_task_index') }}">Cancel</a>

{% endblock %}