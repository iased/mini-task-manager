<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Mini Task Manager{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    </head>
    <body>
        <header class="topbar">
            <div class="topbar-left">
                <div class="logo-circle">✓</div>
                <span class="brand">Task Manager</span>
            </div>

            {% if app.user %}
                <div class="topbar-right">
                    <span class="user-email">Welcome, {{ app.user.email }}</span>
                    <a href="{{ path('app_logout') }}" class="logout-link">Logout</a>
                </div>
            {% else %}
                <div class="topbar-right">
                    <a href="{{ path('app_login') }}" class="logout-link">Login</a>
                </div>
            {% endif %}
        </header>

        <main class="page-container">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>